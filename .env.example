# AdMob App IDs (AndroidManifest.xml / Info.plist にも設定が必要)
VITE_ADMOB_APP_ID_ANDROID=ca-app-pub-xxxxxxxxxxxxx~yyyyyyyyyy
VITE_ADMOB_APP_ID_IOS=ca-app-pub-xxxxxxxxxxxxx~yyyyyyyyyy

# AdMob 広告ユニットID
VITE_ADMOB_INTERSTITIAL_ID_ANDROID=ca-app-pub-xxxxxxxxxxxxx/zzzzzzzzzz
VITE_ADMOB_INTERSTITIAL_ID_IOS=ca-app-pub-xxxxxxxxxxxxx/zzzzzzzzzz

# テストモード (true / false)
VITE_ADMOB_TESTING=true
